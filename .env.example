# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=coin_flip_bot
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/coin_flip_bot

# EVM Configuration
# This wallet receives all player deposits and sends all payouts
EVM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
EVM_PRIVATE_KEY=your_private_key_here
EVM_DEV_WALLET=dev_wallet_address_here

# Solana Configuration
# This wallet receives all player deposits and sends all payouts
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=your_private_key_here
SOLANA_DEV_WALLET=dev_wallet_address_here

# Bot Configuration
FLIP_TIMEOUT_SECONDS=180
MAX_CONCURRENT_FLIPS_PER_GROUP=1
NETWORK=mainnet

# Admin User IDs (comma-separated for multiple admins)
# Only these users can use admin commands
ADMIN_IDS=your_telegram_user_id_here

# Supported Tokens (comma-separated)
# Format: NETWORK:TOKEN_ADDRESS:DECIMALS:SYMBOL
# Use "NATIVE" for native tokens (e.g., PAX on Paxeer)
# Example: EVM:NATIVE:18:PAX,EVM:0x86949e4cdb89496490890b67c9cff63ed8efb4b1:6:SID,SOLANA:5w3wVdJaESaJKyLmStM6Hv9UyUkmZ1b9DLQquAqqpump:6:SID
SUPPORTED_TOKENS=EVM:NATIVE:18:PAX,EVM:0x86949e4cdb89496490890b67c9cff63ed8efb4b1:6:SID,SOLANA:5w3wVdJaESaJKyLmStM6Hv9UyUkmZ1b9DLQquAqqpump:6:SID

# Logging
LOG_LEVEL=info
